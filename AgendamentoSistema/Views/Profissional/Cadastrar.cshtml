@model AgendamentoSistema.Models.Profissional
@{
    ViewData["Title"] = "Cadastrar Profissional";
}

<h1>@ViewData["Title"]</h1>

<h4>Profissional</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Cadastrar">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Especialidade" class="control-label"></label>
                <input asp-for="Especialidade" class="form-control"/>
                <span asp-validation-for="Especialidade" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="HorariosDisponiveis" class="control-label">Duração (minutos)</label>
                <input asp-for="HorariosDisponiveis" type="number" min="1" class="form-control" />
                <span asp-validation-for="HorariosDisponiveis" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Agendamentos" class="control-label"></label>
                <input asp-for="Agendamentos" type="datetime-local" class="form-control" />
                <span asp-validation-for="Agendamentos" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Criar" class="btn btn-primary" /> |
                <a asp-action="Index">Voltar para a Lista</a>
            </div>
        </form>
    </div>
</div>
