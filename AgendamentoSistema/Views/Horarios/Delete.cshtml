@model AgendamentoSistema.Models.Horario

@{ ViewData["Title"] = "Excluir Horário"; }

<h1>@ViewData["Title"]</h1>

<h3>Tem certeza que deseja excluir este horário?</h3>

@if (ViewData["ErroExclusao"] != null)
{
    <div class="alert alert-danger" role="alert">
        @ViewData["ErroExclusao"]
    </div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Erro:</strong>
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}


<div>
    <h4>Horário Disponível</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Profissional
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Profissional.Nome)
        </dd>
        <dt class="col-sm-2">
            Início
        </dt>
        <dd class="col-sm-10">
            @Model.DataHoraInicio.ToString("dd/MM/yyyy HH:mm")
        </dd>
        <dt class="col-sm-2">
            Fim
        </dt>
        <dd class="col-sm-10">
            @Model.DataHoraFim.ToString("dd/MM/yyyy HH:mm")
        </dd>
        <dt class="col-sm-2">
            Disponível?
        </dt>
        <dd class="col-sm-10">
            @(Model.Disponivel ? "Sim" : "Não")
        </dd>
    </dl>

    <form asp-action="Delete">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        @* Só permite excluir se não houver erro *@
        @if (ViewData["ErroExclusao"] == null && ViewData.ModelState.IsValid)
        {
            <input type="submit" value="Excluir" class="btn btn-danger" /> 
        }
        else
        {
             <input type="submit" value="Excluir" class="btn btn-danger" disabled="disabled" title="Não é possível excluir este horário."/>
        }
         |
        <a asp-action="Index">Voltar para a Lista</a>
    </form>
</div>

